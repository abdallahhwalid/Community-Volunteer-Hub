<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My Profile – Community Help Hub</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="/css/profile.css"/>
  <script>
    (function () {
      var saved = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body>

  <nav class="navbar">
    <a href="/" class="nav-logo">
      <div class="nav-logo-icon"><img src="/images/logo.png" alt="Community Help Hub logo"></div>
      <span class="nav-logo-text">Community Help Hub</span>
    </a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/requests">Browse</a></li>
      <li><a href="/requests/my">My Requests</a></li>
    </ul>
    <div class="nav-icons">
      <button class="nav-icon-btn dark-toggle" id="darkToggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <span id="darkIcon">🌙</span>
      </button>
      <a href="/messages" class="nav-icon-btn" title="Messages"><img src="/images/messages1.png" alt="messages" class="nav-icon-img-sm"></a>
      <a href="/profile" class="nav-icon-btn"><img src="/images/profile.png" alt="profile" class="nav-icon-img-md"></a>
      <a href="/logout" class="btn-nav-login">Logout</a>
    </div>
  </nav>

  <main class="main-content">
    <div class="page-header">
      <h1>My Profile</h1>
      <p>Manage your information and skills</p>
    </div>

    <div class="profile-page">
      <form id="profile-form" action="/profile" method="POST" enctype="multipart/form-data">

        <div class="profile-card">
          <h2 class="profile-card-title">Profile Information</h2>
          <p class="profile-card-sub">Update your photo and personal details</p>

          <div class="profile-avatar-row">
            <div class="avatar-wrap">
              <% if (user.photo && user.photo !== '/images/default-avatar.png') { %>
                <img id="avatar-img" src="<%= user.photo %>" alt="Profile photo" style="width:80px;height:80px;border-radius:50%;object-fit:cover;"/>
                <div class="avatar avatar-lg d-none" id="avatar-initials"><%= user.name.charAt(0).toUpperCase() %></div>
              <% } else { %>
                <div class="avatar avatar-lg" id="avatar-initials"><%= user.name.charAt(0).toUpperCase() %></div>
                <img id="avatar-img" src="" alt="Profile photo" class="d-none"/>
              <% } %>
              <input type="file" id="photo-upload" name="photo" accept=".jpg,.jpeg,.png,image/jpeg,image/png" class="d-none" onchange="handlePhotoUpload(event)"/>
              <button type="button" class="avatar-edit-btn" title="Upload photo" onclick="document.getElementById('photo-upload').click()">📷</button>
            </div>

            <div class="profile-info">
              <h3 id="display-name"><%= user.name %></h3>
              <div class="meta-info">📍 <span id="display-location"><%= user.location || 'Location' %></span></div>
              <div class="meta-info">📅 Joined <%= user.joinedAt.toDateString() %></div>
              <div class="stars">
                <% var filled = Math.floor(user.rating || 0); %>
                <% for (var i = 1; i <= 5; i++) { %><%= i <= filled ? '★' : '☆' %><% } %>
                <span class="rating-text"><%= user.rating || 0 %></span>
              </div>
            </div>
          </div>

          <p class="photo-hint">Click the 📷 icon to upload a profile photo (JPG, PNG — max 5MB)</p>

          <div class="form-group">
            <label for="full-name">Full Name</label>
            <input type="text" id="full-name" name="name" class="form-control" value="<%= user.name %>" oninput="updatePreview()"/>
          </div>

          <div class="form-group">
            <label for="location">📍 Your Location</label>
            <input type="text" id="location" name="location" class="form-control" value="<%= user.location %>" placeholder="e.g., Cairo, Nasr City" oninput="updatePreview()"/>
            <span class="form-hint">This helps volunteers near you find your requests</span>
          </div>

          <div class="form-group">
            <label for="bio">Bio <span class="text-optional">(optional)</span></label>
            <textarea id="bio" name="bio" class="form-control" maxlength="200"><%= user.bio %></textarea>
            <span id="bio-counter" class="form-hint"><%= user.bio.length %> / 200 characters</span>
          </div>
        </div>

        <div class="profile-card">
          <h2 class="profile-card-title">My Skills</h2>
          <p class="profile-card-sub">Add skills you can offer to help others.</p>

          <p class="skills-label skills-label-top">Quick pick — click to add:</p>
          <div class="suggested-skills" id="suggested-skills">
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">IT Repair</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Gardening</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Tutoring</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Home Tasks</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Cooking</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Driving</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Pet Care</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Plumbing</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Photography</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Language Help</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Medical Advice</button>
            <button type="button" class="skill-suggestion" onclick="addSuggestedSkill(this)">Child Care</button>
          </div>

          <p class="skills-label skills-label-mid">Your skills:</p>
          <div class="skills-container" id="skills-container">
            <% if (user.skills.length === 0) { %>
              <span class="no-skills-text" id="no-skills-msg">No skills added yet.</span>
            <% } else { %>
              <% user.skills.forEach(function(skill) { %>
                <span class="skill-tag" data-skill="<%= skill %>">
                  <%= skill %> <button type="button" onclick="removeSkill(this, '<%= skill %>')">✕</button>
                </span>
              <% }); %>
            <% } %>
          </div>

          <input type="hidden" id="skills-data" name="skills" value="<%= user.skills.join(',') %>"/>

          <div class="custom-skill-row">
            <input type="text" id="skill-input" class="form-control skill-input-flex" placeholder="Or type a custom skill and press Enter..."/>
            <button type="button" class="btn-blue" onclick="addSkill()">+ Add</button>
          </div>

          <div class="tip-box">
            <strong>💡 Tip:</strong> Add specific skills to increase your chances of being matched with relevant requests.
          </div>
        </div>

        <div class="profile-actions">
          <a href="/" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-blue btn-save">Save Changes</button>
        </div>

        <div class="alert-success" id="save-success">✅ Profile saved successfully!</div>
      </form>
    </div>
  </main>

  <footer>
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="nav-logo">
          <div class="nav-logo-icon"><img src="/images/logo.png" alt="Community Help Hub logo"></div>
          <span class="nav-logo-text">Community Help Hub</span>
        </a>
        <p>Connecting local volunteers with people who need help.</p>
        <div class="footer-contact"><span>✉ support@communityhelpub.org</span><span>📞 (555) 123-4567</span></div>
      </div>
      <div class="footer-col"><h4>Quick Links</h4><ul><li><a href="/requests">Browse Requests</a></li><li><a href="/post-request">Post a Request</a></li><li><a href="/about">About Us</a></li><li><a href="/contact">Contact Us</a></li></ul></div>
      <div class="footer-col"><h4>Legal</h4><ul><li><a href="/privacy">Privacy Policy</a></li><li><a href="/terms">Terms of Service</a></li><li><a href="/safety">Safety Guidelines</a></li></ul></div>
    </div>
    <div class="footer-bottom"><p class="footer-copy">© 2026 Community Help Hub. All rights reserved.</p></div>
  </footer>

  <script>
    (function () {
      var btn  = document.getElementById('darkToggle');
      var icon = document.getElementById('darkIcon');
      var html = document.documentElement;
      icon.textContent = html.classList.contains('dark') ? '☀️' : '🌙';
      btn.addEventListener('click', function () {
        var isDark = html.classList.toggle('dark');
        icon.textContent = isDark ? '☀️' : '🌙';
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        applyDarkModeImages();
      });
    })();

    function applyDarkModeImages() {
      const isDark = document.documentElement.classList.contains('dark');

      const logo = document.querySelector('.nav-logo-icon img');
      if (logo) logo.src = isDark ? '/images/dark-mode/logo-dark.png' : '/images/logo.png';

      document.querySelectorAll('.nav-icon-btn img').forEach(function(img) {
        if (img.alt === 'messages') {
          img.src = isDark ? '/images/dark-mode/msgs-dark.png' : '/images/messages1.png';
        }
        if (img.alt === 'profile') {
          img.src = isDark ? '/images/dark-mode/profile-dark.png' : '/images/profile.png';
        }
      });
    }

    applyDarkModeImages();
  </script>
  <script src="/js/profile.js"></script>
</body>
</html>
