<!DOCTYPE html>

<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

<%- include('partials/header') %>
<%- include('partials/nav') %>

  <div class="admin-page">

```
<h1>Admin Dashboard</h1>

<!-- Statistics -->
<div class="stats-grid">

  <div class="stat-card">
    <div class="stat-icon">👥</div>
    <div>
      <div class="stat-number"><%= userCount %></div>
      <div class="stat-label">Total Users</div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon">📋</div>
    <div>
      <div class="stat-number"><%= requestCount %></div>
      <div class="stat-label">Total Requests</div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon">💬</div>
    <div>
      <div class="stat-number"><%= messageCount %></div>
      <div class="stat-label">Total Messages</div>
    </div>
  </div>

</div>

<!-- Recent Users -->
<div class="admin-section">

  <div class="admin-section-header">
    <h2>Recent Users</h2>
  </div>

  <div class="table-wrap">

    <table>

      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Joined</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>

        <% if (recentUsers.length === 0) { %>

          <tr>
            <td colspan="5" style="text-align:center;">
              No users found
            </td>
          </tr>

        <% } else { %>

          <% recentUsers.forEach(user => { %>

            <tr>

              <td><%= user.name %></td>

              <td><%= user.email %></td>

              <td>
                <span class="role-badge role-<%= user.role %>">
                  <%= user.role %>
                </span>
              </td>

              <td>
                <%= user.joinedAt
                  ? user.joinedAt.toLocaleDateString()
                  : 'N/A' %>
              </td>

              <td class="actions-cell">

                <form
                  action="/admin/users/<%= user._id %>?_method=DELETE"
                  method="POST"
                  style="display:inline"
                >
                  <button
                    type="submit"
                    class="btn-delete"
                    onclick="return confirm('Delete this user?')"
                  >
                    Delete
                  </button>
                </form>

              </td>

            </tr>

          <% }) %>

        <% } %>

      </tbody>

    </table>

  </div>

</div>

<!-- Recent Requests -->
<div class="admin-section">

  <div class="admin-section-header">
    <h2>Recent Requests</h2>
  </div>

  <div class="table-wrap">

    <table>

      <thead>
        <tr>
          <th>Title</th>
          <th>Posted By</th>
          <th>Date</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>

        <% if (recentRequests.length === 0) { %>

          <tr>
            <td colspan="4" style="text-align:center;">
              No requests found
            </td>
          </tr>

        <% } else { %>

          <% recentRequests.forEach(request => { %>

            <tr>

              <td><%= request.title %></td>

              <td>
                <%= request.postedBy
                  ? request.postedBy.name
                  : 'Unknown' %>
              </td>

              <td>
                <%= request.createdAt
                  ? request.createdAt.toLocaleDateString()
                  : 'N/A' %>
              </td>

              <td class="actions-cell">

                <form
                  action="/admin/requests/<%= request._id %>?_method=DELETE"
                  method="POST"
                  style="display:inline"
                >
                  <button
                    type="submit"
                    class="btn-delete"
                    onclick="return confirm('Delete this request?')"
                  >
                    Delete
                  </button>
                </form>

              </td>

            </tr>

          <% }) %>

        <% } %>

      </tbody>

    </table>

  </div>

</div>

<!-- Recent Messages -->
<div class="admin-section">

  <div class="admin-section-header">
    <h2>Recent Messages</h2>
  </div>

  <div class="table-wrap">

    <table>

      <thead>
        <tr>
          <th>From</th>
          <th>To</th>
          <th>Message</th>
          <th>Date</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>

        <% if (recentMessages.length === 0) { %>

          <tr>
            <td colspan="6" style="text-align:center;">
              No messages yet
            </td>
          </tr>

        <% } else { %>

          <% recentMessages.forEach(msg => { %>

            <tr>

              <td>
                <%= msg.sender
                  ? msg.sender.name
                  : 'Unknown' %>
              </td>

              <td>
                <%= msg.receiver
                  ? msg.receiver.name
                  : 'Unknown' %>
              </td>

              <td>
                <%= msg.content.length > 50
                  ? msg.content.substring(0, 50) + '...'
                  : msg.content %>
              </td>

              <td>
                <%= msg.createdAt
                  ? msg.createdAt.toLocaleDateString()
                  : 'N/A' %>
              </td>

              <td>

                <span class="role-badge <%= msg.isRead ? 'role-user' : 'role-admin' %>">

                  <%= msg.isRead ? 'Read' : 'Unread' %>

                </span>

              </td>

              <td>

                <form
                  action="/admin/messages/<%= msg._id %>?_method=DELETE"
                  method="POST"
                  style="display:inline"
                >
                  <button
                    type="submit"
                    class="btn-delete"
                    onclick="return confirm('Delete this message?')"
                  >
                    Delete
                  </button>
                </form>

              </td>

            </tr>

          <% }) %>

        <% } %>

      </tbody>

    </table>

  </div>

</div>
```

  </div>

<%- include('partials/footer') %>

</body>
</html>
