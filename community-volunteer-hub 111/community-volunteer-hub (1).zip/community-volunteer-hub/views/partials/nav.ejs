<%# Dark mode is initialized in header.ejs before paint — no flash %>
<nav class="navbar">
  <a href="/" class="nav-logo">
    <div class="nav-logo-icon"><img src="/images/logo.png" alt="Community Help Hub logo"></div>
    <span class="nav-logo-text">Community Help Hub</span>
  </a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/requests">Browse</a></li>
    <% if (user) { %>
      <li><a href="/requests/my">My Requests</a></li>
    <% } %>
  </ul>
  <div class="nav-icons">
    <button class="nav-icon-btn dark-toggle" id="darkToggle" aria-label="Toggle dark mode" title="Toggle dark mode">
      <span id="darkIcon">🌙</span>
    </button>
    <a href="/messages" class="nav-icon-btn">
      <img src="/images/messages1.png" alt="Messages" class="nav-icon-img-sm">
    </a>
    <a href="/profile" class="nav-icon-btn">
      <img src="/images/profile.png" alt="Profile" class="nav-icon-img-md">
    </a>
    <% if (user) { %>
      <span style="font-size:14px; font-weight:600;">Hi, <%= user.name.split(' ')[0] %></span>
      <% if (user.role === 'admin') { %>
        <a href="/admin" class="btn-nav-signup">Admin</a>
      <% } %>
      <a href="/logout" class="btn-nav-login">Logout</a>
    <% } else { %>
      <a href="/login" class="btn-nav-login">Login</a>
      <a href="/register" class="btn-nav-signup">Sign Up</a>
    <% } %>
  </div>
</nav>

<script>
  (function () {
    var btn  = document.getElementById('darkToggle');
    var icon = document.getElementById('darkIcon');
    var html = document.documentElement;
    icon.textContent = html.classList.contains('dark') ? '☀️' : '🌙';
    btn.addEventListener('click', function () {
      var isDark = html.classList.toggle('dark');
      icon.textContent = isDark ? '☀️' : '🌙';
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      applyDarkModeImages();
    });
  })();

  function applyDarkModeImages() {
    const isDark = document.documentElement.classList.contains('dark');

    const logo = document.querySelector('.nav-logo-icon img');
    if (logo) logo.src = isDark ? '/images/dark-mode/logo-dark.png' : '/images/logo.png';

    document.querySelectorAll('.nav-icon-btn img').forEach(function(img) {
      if (img.alt === 'Messages') {
        img.src = isDark ? '/images/dark-mode/msgs-dark.png' : '/images/messages1.png';
      }
      if (img.alt === 'Profile') {
        img.src = isDark ? '/images/dark-mode/profile-dark.png' : '/images/profile.png';
      }
    });
  }

  applyDarkModeImages();
</script>
    
      
