<nav class="navbar">
  <a href="/" class="nav-logo">
    <div class="nav-logo-icon"><img src="/images/logo.png" alt="Community Help Hub logo"></div>
    <span class="nav-logo-text">Community Help Hub</span>
  </a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/requests">Browse</a></li>
    <% if (user) { %>
      <li><a href="/requests/my">My Requests</a></li>
    <% } %>
  </ul>
  <div class="nav-icons">
    <a href="/messages" class="nav-icon-btn">
      <img src="/images/messages1.png" alt="Messages" class="nav-icon-img-sm">
    </a>
    <a href="/profile" class="nav-icon-btn">
      <img src="/images/profile.png" alt="Profile" class="nav-icon-img-md">
    </a>
    <% if (user) { %>
      <span style="font-size:14px; font-weight:600;">Hi, <%= user.name.split(' ')[0] %></span>
      <a href="/logout" class="btn-nav-login">Logout</a>
    <% } else { %>
      <a href="/login" class="btn-nav-login">Login</a>
      <a href="/register" class="btn-nav-signup">Sign Up</a>
    <% } %>
  </div>
</nav>