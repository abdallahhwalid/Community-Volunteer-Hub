<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Messages</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/messages.css">
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/nav') %>

  <div class="messages-container">
    <h1>My Messages</h1>

    <% if (messages.length === 0) { %>
      <p>No messages yet.</p>
    <% } else { %>
      <div class="messages-list">
        <% messages.forEach(msg => { %>
          <div class="message-card <%= msg.isRead ? '' : 'unread' %>">
            <div class="message-info">
              <span class="message-from">
                <% if (msg.sender._id.toString() === currentUser._id.toString()) { %>
                  To: <strong><%= msg.receiver.name %></strong>
                <% } else { %>
                  From: <strong><%= msg.sender.name %></strong>
                <% } %>
              </span>
              <span class="message-time"><%= msg.createdAt.toLocaleDateString() %></span>
            </div>
            <p class="message-content"><%= msg.content %></p>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Send Message Form -->
    <div class="send-message">
      <h2>Send a Message</h2>
      <form action="/messages/send" method="POST">
        <input type="text" name="receiverId" placeholder="Receiver ID" required />
        <textarea name="content" placeholder="Write your message..." required></textarea>
        <button type="submit">Send</button>
      </form>
    </div>
  </div>

  <%- include('partials/footer') %>
</body>
</html>