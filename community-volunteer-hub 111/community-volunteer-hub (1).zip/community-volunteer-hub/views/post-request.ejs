<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Post a Request – Community Help Hub</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="/css/forms.css"/>

  <script>
  (function () {
    var saved = localStorage.getItem('theme');
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (saved === 'dark' || (!saved && prefersDark)) {
      document.documentElement.classList.add('dark');
    }
  })();
</script>

</head>
<body>

  <%- include('partials/nav') %>

  <main class="main-content">
    <div class="form-page">
      <div class="form-page-header">
        <h1>Post a Help Request</h1>
        <p>Describe what you need help with and our volunteers will reach out</p>
      </div>

      <div class="form-box">
        <p class="form-box-title">Request Details</p>
        <p class="form-box-sub">Be as specific as possible to help volunteers understand your needs</p>

        <% if (errors && errors.length > 0) { %>
          <div style="background:#fee2e2; border:1px solid #fca5a5; border-radius:8px; padding:12px 16px; margin-bottom:20px;">
            <% errors.forEach(err => { %>
              <p style="color:#dc2626; font-size:14px; margin:0 0 4px;">⚠ <%= err %></p>
            <% }) %>
          </div>
        <% } %>

        <form id="post-request-form" method="POST" action="/requests" enctype="multipart/form-data" novalidate>

<div class="form-group">
  <label>Request Type *</label>
  <div style="display:flex; gap:12px; margin-top:4px;">
    <label id="inperson-label" style="flex:1; display:flex; align-items:center; gap:10px;
      padding:12px 16px; border-radius:8px; cursor:pointer;
      border:2px solid var(--navy); background:var(--blue-light); transition:all 0.2s;">
      <input type="radio" name="requestType" value="in-person" checked
        onchange="setRequestType('in-person')" style="accent-color:var(--navy)"/>
      <span>
        <span style="font-size:16px;">📍</span>
        <strong style="font-size:14px; margin-left:6px;">In-Person</strong><br/>
        <span style="font-size:12px; color:var(--text-gray);">Volunteer comes to you or you meet locally</span>
      </span>
    </label>

    <label id="online-label" style="flex:1; display:flex; align-items:center; gap:10px;
      padding:12px 16px; border-radius:8px; cursor:pointer;
      border:2px solid var(--border); background:white; transition:all 0.2s;">
      <input type="radio" name="requestType" value="online"
        onchange="setRequestType('online')" style="accent-color:#4338CA"/>
      <span>
        <span style="font-size:16px;">🌐</span>
        <strong style="font-size:14px; margin-left:6px;">Online</strong><br/>
        <span style="font-size:12px; color:var(--text-gray);">Help via video call, chat, or remote access</span>
      </span>
    </label>
  </div>

  <div id="online-notice" style="display:none; margin-top:10px; padding:10px 14px;
    background:#EEF2FF; border-radius:8px; font-size:13px; color:#4338CA; font-weight:500;">
    🌐 <strong>Online request</strong> — no physical location needed.
  </div>
</div>

          <div class="form-group">
            <label for="title">Request Title *</label>
            <input type="text" id="title" name="title" class="form-control"
              placeholder="e.g., Need help moving furniture"
              value="<%= old.title || '' %>"/>
            <span class="error-msg" id="title-error"></span>
          </div>

          <div class="form-group">
            <label for="category">Category *</label>
            <select id="category" name="category" class="form-control">
              <option value="">Select a category</option>
              <% ['Home Tasks','IT Repair','Gardening','Tutoring','Pet Care','Transportation','Other'].forEach(cat => { %>
                <option value="<%= cat %>" <%= (old.category === cat) ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
            <span class="error-msg" id="category-error"></span>
          </div>

          <div class="form-group">
            <label for="description">Description *</label>
            <textarea id="description" name="description" class="form-control"
              placeholder="Provide detailed information about what you need help with..."><%= old.description || '' %></textarea>
            <p style="font-size:12px; color:var(--text-gray); margin-top:6px;">
              Include important details like the scope of work, time estimate, and any tools needed
            </p>
            <span class="error-msg" id="description-error"></span>
          </div>

         <div class="form-group" id="location-group">
  <label for="location">📍 Location *</label>
  <input type="text" id="location" name="location" class="form-control"
    placeholder="e.g., Downtown, 123 Main St"
    value="<%= old.location || '' %>"/>
  <span class="error-msg" id="location-error"></span>
</div>
          <div class="form-row">
            <div class="form-group">
              <label for="desired-date">📅 Desired Date</label>
              <input type="date" id="desired-date" name="desiredDate" class="form-control"
                min="2026-01-01"
                value="<%= old.desiredDate || '' %>"/>
            </div>
            <div class="form-group">
              <label for="desired-time">Desired Time</label>
              <input type="time" id="desired-time" name="desiredTime" class="form-control"
                value="<%= old.desiredTime || '' %>"/>
            </div>
          </div>

          <label class="flexible-check">
            <input type="checkbox" id="flexible" name="flexible" style="width:16px;height:16px;"
              <%= old.flexible === 'on' ? 'checked' : '' %>/>
            I'm flexible with timing and can coordinate with the volunteer
          </label>

          <div class="form-group" style="margin-top:20px;">
            <label for="image">📷 Add a Photo <span style="color:var(--text-gray); font-weight:400;">(optional)</span></label>
            <input type="file" id="image" name="image" class="form-control"
              accept="image/jpeg, image/png, image/gif, image/webp"
              onchange="previewImage(event)"
              style="padding:8px;"/>
            <p style="font-size:12px; color:var(--text-gray); margin-top:6px;">
              Upload a photo of what you need help with. Max 5MB. JPG, PNG, GIF, or WEBP.
            </p>
            <div id="image-preview-wrap" style="display:none; margin-top:12px;">
              <img id="image-preview" src="" alt="Preview"
                style="max-width:100%; max-height:200px; border-radius:8px; border:1px solid #e5e7eb;"/>
              <button type="button" onclick="clearImage()"
                style="display:block; margin-top:6px; font-size:13px; color:#dc2626; background:none; border:none; cursor:pointer;">
                ✕ Remove photo
              </button>
            </div>
          </div>

          <div class="safety-box">
            <h4>⚠ Safety Reminders</h4>
            <ul>
              <li>Meet in public places when possible</li>
              <li>Verify volunteer identity before sharing personal information</li>
              <li>Trust your instincts and report any suspicious behavior</li>
            </ul>
          </div>

          <div class="form-actions">
            <a href="/requests" class="btn-secondary">Cancel</a>
            <button type="submit" class="btn-primary">Post Request</button>
          </div>

        </form>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    function previewImage(event) {
      const file = event.target.files[0];
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) {
        alert('Image must be smaller than 5MB');
        event.target.value = '';
        return;
      }
      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById('image-preview').src = e.target.result;
        document.getElementById('image-preview-wrap').style.display = 'block';
      };
      reader.readAsDataURL(file);
    }

    function clearImage() {
      document.getElementById('image').value = '';
      document.getElementById('image-preview').src = '';
      document.getElementById('image-preview-wrap').style.display = 'none';
    }

 function setRequestType(type) {
    const isOnline = type === 'online';
    const inpersonLabel = document.getElementById('inperson-label');
    const onlineLabel   = document.getElementById('online-label');
    const locationGroup = document.getElementById('location-group');
    const onlineNotice  = document.getElementById('online-notice');
    const safetyItems   = document.getElementById('safety-items');

    inpersonLabel.style.border     = isOnline ? '2px solid var(--border)' : '2px solid var(--navy)';
    inpersonLabel.style.background = isOnline ? 'white' : 'var(--blue-light)';
    onlineLabel.style.border       = isOnline ? '2px solid #4338CA' : '2px solid var(--border)';
    onlineLabel.style.background   = isOnline ? '#EEF2FF' : 'white';

    locationGroup.style.display = isOnline ? 'none' : '';
    onlineNotice.style.display  = isOnline ? 'block' : 'none';
  }

  </script>

  <script src="/js/validation.js"></script>
</body>
</html>