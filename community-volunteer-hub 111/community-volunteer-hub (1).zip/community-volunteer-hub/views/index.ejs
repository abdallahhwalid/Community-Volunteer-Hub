<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Community Help Hub – Home</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="/css/home.css"/>
  <link rel="stylesheet" href="/css/requests.css"/>
  <script>
    (function () {
      var saved = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body>

  <%- include('partials/nav') %>

  <main class="main-content">

    <section class="hero">
      <div class="hero-content">
        <h1>Help Your Neighbors –<br>Get Help When You Need</h1>
        <p>Building stronger communities by connecting people who need help with volunteers ready to lend a hand.</p>
        <div class="hero-buttons">
          <a href="/requests/new" class="btn-primary">I Need Help</a>
          <a href="/requests" class="btn-hero-outline">I Want to Volunteer</a>
        </div>
      </div>
    </section>

    <section class="section section-white">
      <div class="container container-center">
        <h2 class="section-title">How It Works</h2>
        <p class="section-sub">Getting help or helping others is simple</p>
        <div class="grid-3">
          <div class="how-card">
            <div class="how-icon">
              <img src="/images/dark-mode/sign_up-dark.png" alt="Sign Up">                                                                      
            </div>
            <h3>1. Sign Up</h3>
            <p>Create your free account and add your skills if you want to volunteer.</p>
          </div>
          <div class="how-card">
            <div class="how-icon">
              <img src="/images/dark-mode/post_and_browse-dark.png" alt="Post and Browse">
            </div>
            <h3>2. Post or Browse</h3>
            <p>Post a help request or browse existing requests to find someone to help.</p>
          </div>
          <div class="how-card">
            <div class="how-icon">
              <img src="/images/dark-mode/connect_and_help-dark.png" alt="Connect and Help">
            </div>
            <h3>3. Connect & Help</h3>
            <p>Message each other to coordinate, complete the task, and rate your experience.</p>
          </div>
        </div>
      </div>
    </section>

   <section class="section section-bg">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title section-title-sm">Recent Help Requests</h2>
            <p class="section-desc">People in your community need your help</p>
          </div>
          <a href="/requests" class="btn-ghost">View All</a>
        </div>
        <div class="grid-4 grid-stretch">
          <% if (recentRequests && recentRequests.length > 0) { %>
            <% recentRequests.forEach(function(req) { %>
              <div class="card card-full">
                <div class="card-top-row">
                  <span class="badge <%= req.status === 'Open' ? 'badge-open' : req.status === 'In Progress' ? 'badge-progress' : 'badge-completed' %>"><%= req.status %></span>
                  <span class="card-time"><%= new Date(req.createdAt).toLocaleDateString() %></span>
                </div>

                <% var isOnline = (req.requestType === 'online' || req.location === 'Online') ? true : false; %>
                <%if (isOnline) { %>
                <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;background:#EEF2FF;color:#4338CA;border:1px solid #C7D2FE;border-radius:6px;padding:2px 8px;margin-bottom:6px;">🌐 Online</span>
                <% } else { %>
                <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;background:#D1FAE5;color:#065F46;border:1px solid #6EE7B7;border-radius:6px;padding:2px 8px;margin-bottom:6px;">📍 In-Person</span>
                  <% } %>
                <h4 class="card-title"><%= req.title %></h4>
                <p class="card-category"><%= req.category %></p>
                <p class="req-desc" style="font-size:13px; color:var(--text-gray); margin:4px 0 6px; line-height:1.5;">
                   <%= req.description ? req.description.substring(0, 80) + '...' : '' %>
                </p>
                <div class="meta-info">📍 <%= req.location %></div>
                
          <% if (req.status === 'In Progress') { %>
              <a href="/requests" class="btn-offer btn-offer-full" style="background:#e5e7eb;color:#9ca3af;cursor:not-allowed;text-align:center;pointer-events:none;">🔄 In Progress</a>
           <% } else if (req.status === 'Completed') { %>
              <a href="/requests" class="btn-offer btn-offer-full" style="background:#e5e7eb;color:#9ca3af;cursor:not-allowed;text-align:center;pointer-events:none;">✅ Completed</a>
           <% } else if (user) { %>
          <% var posterName = req.postedBy ? req.postedBy.name : "Someone"; %>
        <button class="btn-offer btn-offer-full"
          data-id="<%= req._id %>"
          data-title="<%= req.title.replace(/'/g, '') %>"
          data-category="<%= req.category %>"
          data-location="<%= req.location.replace(/'/g, '') %>"
          data-user="<%= posterName.replace(/'/g, '') %>"
          data-type="<%= isOnline ? 'online' : 'inperson' %>"
         onclick="(function(btn){ openOfferModal(btn.dataset.id, btn.dataset.title, btn.dataset.category, btn.dataset.location, btn.dataset.user, btn.dataset.type); })(this)">
    Offer Help
  </button>
<% } else { %>
  <a href="/login" class="btn-offer btn-offer-full" style="text-align:center;">Login to Offer Help</a>
<% } %>
              </div>
            <% }); %>
          <% } else { %>
            <p style="color:var(--text-gray);">No open requests yet. Be the first to post one!</p>
          <% } %>
        </div>
      </div>
    </section>

    <section class="section section-white">
      <div class="container container-center">
        <h2 class="section-title">Top Volunteers</h2>
        <p class="section-sub">Meet our most helpful community members</p>
        <div class="grid-4">
          <% if (topVolunteers && topVolunteers.length > 0) { %>
            <% topVolunteers.forEach(function(volunteer) { %>
              <div class="card volunteer-card">
                <div class="avatar avatar-lg volunteer-avatar">
                  <%= volunteer.name.charAt(0).toUpperCase() %>
                </div>
                <h4 class="volunteer-name"><%= volunteer.name %></h4>
                <p class="volunteer-skill"><%= volunteer.skills && volunteer.skills[0] ? volunteer.skills[0] : 'Volunteer' %></p>
                <div class="stars">
                  <% var vFilled = Math.floor(volunteer.rating || 0); %>
                  <% for (var i = 1; i <= 5; i++) { %><%= i <= vFilled ? '★' : '☆' %><% } %>
                  <span class="volunteer-rating"><%= volunteer.rating || 0 %></span>
                </div>
                <a href="/profile/<%= volunteer._id %>" class="btn-primary btn-profile">View Profile</a>
              </div>
            <% }); %>
          <% } else { %>
            <p style="color:var(--text-gray);">No volunteers yet. Sign up and add your skills!</p>
          <% } %>
        </div>
      </div>
    </section>

    <section class="cta-banner">
      <h2>Ready to Make a Difference?</h2>
      <p>Join thousands of community members helping each other every day.</p>
      <a href="/register" class="btn-primary btn-cta">Get Started Today</a>
    </section>

  </main>

  <!-- Offer Modal -->
<div id="offer-modal" class="modal-overlay" style="display:none;">
    <div class="modal-content">
      <h2 id="modal-title" style="word-break:break-word; overflow-wrap:break-word; white-space:normal; max-width:100%; font-size:clamp(14px, 3vw, 24px);"></h2>
      <p id="modal-category" class="modal-cat"></p>
      <div id="modal-online-badge" style="display:none; margin-bottom:8px;">
        <span style="background:#EEF2FF;color:#4338CA;border:1px solid #C7D2FE;border-radius:6px;padding:4px 10px;font-size:12px;font-weight:700;">🌐 Online Meeting</span>
      </div>
      <div class="modal-grid" id="modal-location-wrap">
        <div class="modal-item">
          <label>Location</label>
          <p id="modal-location"></p>
        </div>
      </div>

      <div class="modal-section">
        <label>Requested by</label>
        <div class="user-info"><span id="modal-user"></span></div>
      </div>
      <div class="modal-section time-picker-box">
        <label>Set your convenient time</label>
       <input type="datetime-local" id="suggested-time" class="form-control"
  id="suggested-time">
      </div>
      <div id="offer-msg" style="display:none; margin-top:10px; font-size:14px;"></div>
      <div class="modal-footer">
        <button class="btn-secondary" onclick="closeOfferModal()">Cancel</button>
        <button class="btn-primary" id="confirm-help-btn" onclick="confirmHelp()">Contact to Help</button>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    let currentRequestId = null;

    function openOfferModal(id, title, category, location, user, type) {
  var isOnline = type === 'online';
  currentRequestId = id;
  document.getElementById('modal-title').textContent    = title;
  document.getElementById('modal-category').textContent = category;
  document.getElementById('modal-user').textContent     = user;
  document.getElementById('offer-msg').style.display    = 'none';

  const onlineBadge  = document.getElementById('modal-online-badge');
  const locationWrap = document.getElementById('modal-location-wrap');
  const confirmBtn   = document.getElementById('confirm-help-btn');

  if (isOnline) {
    onlineBadge.style.display  = 'block';
    locationWrap.style.display = 'none';
    confirmBtn.textContent     = '📅 Schedule Meeting';
  } else {
    onlineBadge.style.display  = 'none';
    locationWrap.style.display = '';
    document.getElementById('modal-location').textContent = location;
    confirmBtn.textContent     = 'Contact to Help';
  }

  const now = new Date();
now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
document.getElementById('suggested-time').min = now.toISOString().slice(0, 16);

  document.getElementById('offer-modal').style.display = 'flex';
document.getElementById('offer-modal').style.pointerEvents = 'all';
}

    function closeOfferModal() {
  document.getElementById('offer-modal').style.display = 'none';
  
}

    async function confirmHelp() {
      const suggestedTime = document.getElementById('suggested-time').value;
      const btn = document.getElementById('confirm-help-btn');

      if (!suggestedTime) {
        const timeInput = document.getElementById('suggested-time');
        timeInput.style.borderColor = '#dc2626';
        const msgEl = document.getElementById('offer-msg');
        msgEl.style.display = 'block';
        msgEl.style.color = 'red';
        msgEl.textContent = 'Please select a date and time before continuing.';
        timeInput.focus();
        return;
      }

      document.getElementById('suggested-time').style.borderColor = '';
      btn.disabled = true;
      btn.textContent = 'Sending...';
      try {
        const res = await fetch(`/requests/${currentRequestId}/offer`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ suggestedTime })
        });
        const data = await res.json();
        const msgEl = document.getElementById('offer-msg');
        msgEl.style.display = 'block';
        msgEl.style.color = data.success ? 'green' : 'red';
        msgEl.textContent = data.message;

       if (data.success) {
          btn.textContent = '✓ Sent!';
          const posterName = document.getElementById('modal-user').textContent;
          const requestTitle = document.getElementById('modal-title').textContent;
          closeOfferModal();
          window.location.href = `/messages?autoMsg=true&datetime=${encodeURIComponent(suggestedTime)}&user=${encodeURIComponent(posterName)}&requestTitle=${encodeURIComponent(requestTitle)}`;
        } else {
          btn.disabled = false;
          btn.textContent = 'Contact to Help';
        }
      } catch (err) {
        btn.disabled = false;
        btn.textContent = 'Contact to Help';
      }
    }
  </script>
<script>
    function applyDarkModeImages() {
      const isDark = document.documentElement.classList.contains('dark');

      const logo = document.querySelector('.nav-logo-icon img');
      if (logo) logo.src = isDark ? '/images/dark-mode/logo-dark.png' : '/images/logo.png';

      document.querySelectorAll('.nav-icon-btn img').forEach(function(img) {
        if (img.alt === 'Messages') {
          img.src = isDark ? '/images/dark-mode/msgs-dark.png' : '/images/messages1.png';
        }
        if (img.alt === 'Profile') {
          img.src = isDark ? '/images/dark-mode/profile-dark.png' : '/images/profile.png';
        }
      });
    }

    function applyHowIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.how-icon-img').forEach(function(img) {
        img.src = isDark ? img.dataset.dark : img.dataset.light;
      });
    }

    applyHowIcons();
    applyDarkModeImages();

    const observer = new MutationObserver(function() {
      applyDarkModeImages();
      applyHowIcons();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  </script>



</body>
</html>