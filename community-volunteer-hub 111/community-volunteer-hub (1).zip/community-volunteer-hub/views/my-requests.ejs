<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My Requests – Community Help Hub</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="/css/requests.css"/>
  <style>
    @keyframes popIn {
      from { transform: scale(0.88) translateY(16px); opacity: 0; }
      to   { transform: scale(1) translateY(0); opacity: 1; }
    }
    .toast-notification {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px);
      background: #1E3A8A; color: #fff; padding: 12px 24px; border-radius: 12px;
      font-size: 14px; font-weight: 600; opacity: 0; transition: all 0.3s ease; z-index: 9999;
    }
    .toast-notification.visible { opacity: 1; transform: translateX(-50%) translateY(0); }
    .edit-form-inner { display:flex; flex-direction:column; gap:10px; margin-top:12px; padding:16px; background:#f9fafb; border-radius:12px; border:1px solid #e5e7eb; }
    .edit-label { font-size:13px; font-weight:600; color:#374151; }
    .edit-input { padding:10px 12px; border:1.5px solid #e5e7eb; border-radius:8px; font-size:14px; outline:none; }
    .edit-input:focus { border-color:#1E3A8A; }
    .edit-form-actions { display:flex; gap:10px; margin-top:4px; }
    .online-badge {
      display:inline-block; font-size:11px; font-weight:700; background:#EEF2FF;
      color:#4338CA; border-radius:6px; padding:2px 8px; margin-left:6px;
    }
  </style>
  <script>
  (function () {
    var saved = localStorage.getItem('theme');
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (saved === 'dark' || (!saved && prefersDark)) {
      document.documentElement.classList.add('dark');
    }
  })();
</script>
</head>
<body>

  <%- include('partials/nav') %>

  <!-- Confirm Modal -->
  <div id="confirm-modal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.45); backdrop-filter:blur(4px); align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:20px; padding:40px 36px; max-width:420px; width:90%; text-align:center; box-shadow:0 24px 60px rgba(0,0,0,0.18); animation:popIn .25s cubic-bezier(.34,1.56,.64,1);">
      <div id="modal-icon" style="width:64px; height:64px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:30px;"></div>
      <h3 id="modal-title-text" style="font-size:20px; font-weight:700; color:#111827; margin:0 0 10px;"></h3>
      <p id="modal-msg-text" style="font-size:14px; color:#6b7280; line-height:1.6; margin:0 0 28px;"></p>
      <div style="display:flex; gap:12px;">
        <button id="modal-cancel-btn" style="flex:1; padding:13px 0; border-radius:12px; font-size:14px; font-weight:600; cursor:pointer; background:#f3f4f6; color:#374151; border:1.5px solid #e5e7eb;"></button>
        <button id="modal-confirm-btn" style="flex:1; padding:13px 0; border-radius:12px; font-size:14px; font-weight:600; cursor:pointer; color:#fff; border:none;"></button>
      </div>
    </div>
  </div>

  <main class="main-content">
    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center;">
      <div>
        <h1>My Requests</h1>
        <p>Manage your help requests and volunteering activities</p>
      </div>
      <a href="/requests/new" class="btn-primary">+ Post New Request</a>
    </div>

    <div class="section" style="padding-top:32px;">
      <div class="tabs">
        <button class="tab-btn active" id="tab-posted"  onclick="switchTab('posted')">Requests I Posted (<%= postedRequests.length %>)</button>
        <button class="tab-btn"        id="tab-helping" onclick="switchTab('helping')">Requests I'm Helping With (<%= helpingRequests.length %>)</button>
      </div>

      <!-- TAB: POSTED — Server already filtered out Cancelled -->
      <div id="panel-posted" style="display:flex; flex-direction:column; gap:16px;">

        <% if (postedRequests.length === 0) { %>
          <p style="color:var(--text-gray); padding:24px 0;">No requests yet. <a href="/requests/new">Post one!</a></p>
        <% } %>

        <% postedRequests.forEach(req => { %>
          <%
            const isOnline = ['IT Repair', 'Tutoring'].includes(req.category);
          %>
          <div class="my-req-item" id="req-<%= req._id %>">
            <div class="my-req-header">
              <div class="my-req-header-top">
                <span class="badge <%= req.status === 'Open' ? 'badge-open' : req.status === 'In Progress' ? 'badge-progress' : 'badge-completed' %>">
                  <%= req.status %>
                </span>
                <span style="font-size:13px; color:#6b7280;"><%= req.category %></span>
                <% if (isOnline) { %><span class="online-badge">🌐 Online</span><% } %>
              </div>
              <h3 class="req-title"><%= req.title %></h3>
            </div>

            <div class="my-req-meta">
              <% if (isOnline) { %>
                <span class="meta-info">🌐 Online Meeting</span>
              <% } else { %>
                <span class="meta-info">📍 <span class="req-location"><%= req.location %></span></span>
              <% } %>
              <% if (req.desiredDate) { %>
                <span class="meta-info">🕐 <span class="req-date"><%= new Date(req.desiredDate).toDateString() %></span></span>
              <% } %>
            </div>

            <% if ((req.status === 'In Progress' || req.status === 'Completed') && req.acceptedVolunteer) { %>
              <div class="helper-box">
                <div class="helper-info">
                  <span class="helper-label"><%= req.status === 'Completed' ? 'Helped by:' : 'Being helped by:' %></span>
                  <span class="helper-name"><%= req.acceptedVolunteer.name %></span>
                </div>
                <a href="/messages" class="btn-ghost">Message</a>
              </div>
            <% } %>

          <% if (req.status === 'Completed') { %>
  <p style="font-size:13px;color:#6b7280;">
    Completed on <%= new Date(req.updatedAt).toDateString() %>
  </p>
  <% if (req.acceptedVolunteer) { %>
    <div class="rating-box" id="rating-<%= req._id %>"
      style="margin-top:10px; padding:12px; background:#FFFBEB; border-radius:10px; border:1px solid #FDE68A;">
      <p style="font-size:13px; font-weight:600; color:#92400E; margin-bottom:6px;">
        ⭐ Rate your volunteer:
      </p>
      <div style="display:flex; gap:6px;">
        <% var volId = req.acceptedVolunteer._id; %>
        <% var reqId = req._id; %>
        <% for(var s = 1; s <= 5; s++) { %>
          <button type="button"
           onclick="submitRating('<%= reqId %>', '<%= volId %>', '<%= s %>')"
            style="font-size:24px; background:none; border:none; cursor:pointer; color:#D1D5DB;">
            ☆
          </button>
        <% } %>
      </div>
    </div>
  <% } %>
<% } %>

            <% if (req.pendingOffers && req.pendingOffers.length > 0) { %>
              <div style="margin-top:12px;">
                <h4 style="font-size:14px; margin-bottom:8px;">Pending Help Offers (<%= req.pendingOffers.length %>)</h4>
                <% req.pendingOffers.forEach(offer => { %>
                  <div class="helper-box" id="offer-<%= offer._id %>" style="margin-bottom:8px;">
                    <div class="helper-info">
                      <span class="helper-name"><%= offer.volunteer.name %></span>
                      <% if (offer.suggestedTime) { %>
                        <span style="font-size:12px; color:#6b7280;">
                          <%= isOnline ? '📅 Meeting:' : '⏰ Available:' %>
                          <%= new Date(offer.suggestedTime).toLocaleString() %>
                        </span>
                      <% } %>
                    </div>
                    <div style="display:flex; gap:8px;">
                      <button class="btn-blue" style="font-size:13px; padding:6px 12px;" onclick="respondOffer('<%= offer._id %>','accept')">Accept</button>
                      <button class="btn-danger" style="font-size:13px; padding:6px 12px;" onclick="respondOffer('<%= offer._id %>','reject')">Reject</button>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>

            <div class="my-req-actions">
              <% if (req.status === 'Open') { %>
                <button class="btn-ghost" onclick="editRequest(this)">Edit</button>
                <!-- Cancel: removes from DOM permanently, server stores as Cancelled (never shown again) -->
                <button class="btn-danger" onclick="cancelRequest(this, '<%= req._id %>')">Cancel Request</button>
              <% } %>
              <% if (req.status === 'In Progress') { %>
                <button class="btn-blue" onclick="markCompleted('<%= req._id %>')">Mark as Completed</button>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- TAB: HELPING -->
      <div id="panel-helping" style="display:none; flex-direction:column; gap:16px;">

        <% if (helpingRequests.length === 0) { %>
          <p style="color:var(--text-gray); padding:24px 0;">Not helping with anything yet. <a href="/requests">Browse requests!</a></p>
        <% } %>

        <% helpingRequests.forEach(offer => { %>
          <% const req = offer.request; %>
          <%
            const isOnlineHelp = req && ['IT Repair', 'Tutoring'].includes(req.category);
          %>
          <div class="my-req-item" id="helping-<%= offer._id %>">
            <div class="my-req-header">
              <div class="my-req-header-top">
                <span class="badge <%= offer.status === 'Accepted' ? 'badge-progress' : offer.status === 'Rejected' ? 'badge-cancelled' : 'badge-open' %>">
                  Offer: <%= offer.status %>
                </span>
                <span style="font-size:13px; color:#6b7280;"><%= req.category %></span>
                <% if (isOnlineHelp) { %><span class="online-badge">🌐 Online</span><% } %>
              </div>
              <h3 class="req-title"><%= req.title %></h3>
            </div>

            <div class="my-req-meta">
              <% if (isOnlineHelp) { %>
                <span class="meta-info">🌐 Online Meeting</span>
              <% } else { %>
                <span class="meta-info">📍 <%= req.location %></span>
              <% } %>
              <% if (offer.suggestedTime) { %>
                <span class="meta-info">
                  <%= isOnlineHelp ? '📅 Meeting time:' : '🕐 Your time:' %>
                  <%= new Date(offer.suggestedTime).toLocaleString() %>
                </span>
              <% } %>
            </div>

            <div class="helper-box">
              <div class="helper-info">
                <span class="helper-label">Requested by:</span>
                <span class="helper-name"><%= req.postedBy ? req.postedBy.name : 'Unknown' %></span>
              </div>
              <a href="/messages" class="btn-ghost">Message</a>
            </div>

            <div class="my-req-actions">
              <% if (offer.status === 'Accepted' && req.status === 'In Progress') { %>
                <button class="btn-blue" onclick="markCompleted('<%= req._id %>')">Mark as Completed</button>
              <% } %>
              <% if (offer.status === 'Pending') { %>
                <button class="btn-ghost" onclick="withdrawOffer(this, '<%= offer._id %>')">Withdraw Offer</button>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>

    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    function switchTab(tab) {
      document.getElementById('panel-posted').style.display  = tab === 'posted'  ? 'flex' : 'none';
      document.getElementById('panel-helping').style.display = tab === 'helping' ? 'flex' : 'none';
      document.getElementById('tab-posted').classList.toggle('active',  tab === 'posted');
      document.getElementById('tab-helping').classList.toggle('active', tab === 'helping');
    }

    function showConfirmModal(icon, iconBg, title, message, cancelLabel, confirmLabel, confirmBg, confirmHover, onConfirm) {
      const modal = document.getElementById('confirm-modal');
      document.getElementById('modal-icon').textContent          = icon;
      document.getElementById('modal-icon').style.background     = iconBg;
      document.getElementById('modal-title-text').textContent    = title;
      document.getElementById('modal-msg-text').textContent      = message;
      document.getElementById('modal-cancel-btn').textContent    = cancelLabel;
      document.getElementById('modal-confirm-btn').textContent   = confirmLabel;
      document.getElementById('modal-confirm-btn').style.background = confirmBg;
      document.getElementById('modal-confirm-btn').onmouseenter  = function() { this.style.background = confirmHover; };
      document.getElementById('modal-confirm-btn').onmouseleave  = function() { this.style.background = confirmBg; };
      document.getElementById('modal-cancel-btn').onclick        = hideConfirmModal;
      document.getElementById('modal-confirm-btn').onclick       = () => { hideConfirmModal(); onConfirm(); };
      modal.style.display = 'flex';
      modal.onclick = e => { if (e.target === modal) hideConfirmModal(); };
    }

    function hideConfirmModal() {
      document.getElementById('confirm-modal').style.display = 'none';
    }

    function cancelRequest(btn, id) {
      const item = btn.closest('.my-req-item');
      showConfirmModal(
        '🚫', '#fef2f2',
        'Cancel Request?',
        'This will permanently cancel your request. It will no longer appear in your list.',
        'Keep Request', 'Cancel Request',
        '#dc2626', '#b91c1c',
        async () => {
          try {
            const data = await fetch(`/requests/${id}`, { method: 'DELETE' }).then(r => r.json());
            if (data.success) {
              // Permanently remove from DOM — matches server-side filter (status !== Cancelled)
              Object.assign(item.style, { transition:'all .4s ease', opacity:'0', transform:'scale(0.95)' });
              setTimeout(() => {
                item.remove();
                showToast('Request cancelled and removed.');
              }, 400);
            } else {
              showToast('Error: ' + data.message);
            }
          } catch {
            showToast('Network error. Please try again.');
          }
        }
      );
    }

    async function markCompleted(id) {
      const data = await fetch(`/requests/${id}/complete`, { method: 'PUT' }).then(r => r.json());
      if (data.success) location.reload(); else showToast('Error: ' + data.message);
    }

    async function respondOffer(offerId, action) {
      const data = await fetch(`/requests/offers/${offerId}/${action}`, { method: 'PUT' }).then(r => r.json());
      if (data.success) location.reload(); else showToast('Error: ' + data.message);
    }

    function withdrawOffer(btn, offerId) {
      const item = btn.closest('.my-req-item');
      showConfirmModal(
        '↩️', '#fff7ed',
        'Withdraw from Request?',
        'You will be removed as a helper. The request owner will be notified.',
        'Stay', 'Withdraw',
        '#ea580c', '#c2410c',
        async () => {
          const data = await fetch(`/requests/offers/${offerId}/withdraw`, { method: 'PUT' }).then(r => r.json());
          if (data.success) {
            Object.assign(item.style, { transition:'all .4s ease', opacity:'0', transform:'scale(0.95)' });
            setTimeout(() => item.remove(), 400);
          } else showToast('Error: ' + data.message);
        }
      );
    }

    function editRequest(btn) {
      const item = btn.closest('.my-req-item');
      if (item.querySelector('.edit-form')) return;
      const titleEl    = item.querySelector('.req-title');
      const locationEl = item.querySelector('.req-location');
      const dateEl     = item.querySelector('.req-date');
      const actions    = item.querySelector('.my-req-actions');
      actions.style.display = 'none';
      const form = document.createElement('div');
      form.className = 'edit-form';
      form.innerHTML = `
        <div class="edit-form-inner">
          <label class="edit-label">Title</label>
          <input class="edit-input" id="edit-title" type="text" value="${titleEl ? titleEl.textContent.trim() : ''}"/>
          ${locationEl ? `<label class="edit-label">Location</label>
          <input class="edit-input" id="edit-location" type="text" value="${locationEl.textContent.trim()}"/>` : ''}
          <div class="edit-form-actions">
            <button class="btn-ghost" onclick="cancelEdit(this)">Cancel</button>
            <button class="btn-blue"  onclick="saveEdit(this)">Save Changes</button>
          </div>
        </div>`;
      form._originalActions = actions;
      form._titleEl    = titleEl;
      form._locationEl = locationEl;
      form._dateEl     = dateEl;
      item.appendChild(form);
    }

    function cancelEdit(btn) {
      const form = btn.closest('.edit-form');
      form._originalActions.style.display = '';
      form.remove();
    }

   function saveEdit(btn) {
  const form    = btn.closest('.edit-form');
  const item    = form.closest('.my-req-item');
const reqId   = item.id.replace('req-', '');   // relies on id="req-id_here"  const title   = form.querySelector('#edit-title')?.value.trim();
  const loc     = form.querySelector('#edit-location')?.value.trim();

  if (!title) {
    showToast('Title cannot be empty.');
    return;
  }

  btn.disabled    = true;
  btn.textContent = 'Saving...';

  fetch('/requests/' + reqId, {
    method:  'PUT',
    headers: { 'Content-Type': 'application/json' },
    body:    JSON.stringify({ title: title, location: loc || '' })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      if (form._titleEl    && title) form._titleEl.textContent    = title;
      if (form._locationEl && loc)   form._locationEl.textContent = loc;
      form._originalActions.style.display = '';
      showToast('Request updated!');
      form.remove();
    } else {
      showToast('Error: ' + (data.message || 'Could not update.'));
      btn.disabled    = false;
      btn.textContent = 'Save Changes';
    }
  })
  .catch(function() {
    showToast('Network error. Please try again.');
    btn.disabled    = false;
    btn.textContent = 'Save Changes';
  });
}

    function showToast(msg) {
      const t = document.createElement('div');
      t.className = 'toast-notification';
      t.textContent = msg;
      document.body.appendChild(t);
      requestAnimationFrame(() => t.classList.add('visible'));
      setTimeout(() => { t.classList.remove('visible'); setTimeout(() => t.remove(), 400); }, 3000);
    }

    async function submitRating(requestId, volunteerId, star) {
    const box   = document.getElementById('rating-' + requestId);
    const stars = box.querySelectorAll('button');

    // Highlight selected stars
    stars.forEach((btn, i) => {
      btn.textContent = i < star ? '★' : '☆';
      btn.disabled = true;
    });

    try {
      const res  = await fetch(`/users/${volunteerId}/rate`, {
        method:  'PUT',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ rating: star })
      });
      const data = await res.json();
      if (data.success) {
        box.innerHTML = `<p style="font-size:13px;color:#10B981;font-weight:600;">
          ✅ Rated ${star}/5 — thank you!
        </p>`;
      }
    } catch {
      box.innerHTML = `<p style="font-size:13px;color:red;">Failed to submit rating.</p>`;
    }
  } 
  </script>
</body>
</html>
